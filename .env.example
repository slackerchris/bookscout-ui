# -----------------------------------------------------------------------
# BookScout full-stack environment variable reference
# Copy to .env and fill in your values.
# -----------------------------------------------------------------------

# --- Postgres -----------------------------------------------------------

# Password for the bookscout Postgres user.
# The DATABASE_URL in each service is built from this automatically.
POSTGRES_PASSWORD=bookscout

# --- Required: Audiobookshelf -------------------------------------------

# Base URL of your ABS instance (no trailing slash)
AUDIOBOOKSHELF_URL=http://audiobookshelf:13378

# API token — Settings > Users > (your user) > API Token in ABS
AUDIOBOOKSHELF_TOKEN=your_abs_api_token_here

# --- Optional: Prowlarr -------------------------------------------------

PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=your_prowlarr_api_key_here

# --- Optional: Jackett --------------------------------------------------

# JACKETT_URL=http://jackett:9117
# JACKETT_API_KEY=your_jackett_api_key_here

# --- Optional: external book APIs ---------------------------------------

# Google Books — free key, raises rate limit from ~100 to 1000 req/day
# https://console.cloud.google.com/  → Enable "Books API" → create API key
GOOGLE_BOOKS_API_KEY=

# ISBNdb — paid ($10-50/month), greatly improves ISBN coverage
# https://isbndb.com/isbn-database
ISBNDB_API_KEY=

# --- Optional: download client ------------------------------------------

# Which client to use: sabnzbd | qbittorrent | transmission
DOWNLOAD_PREFERRED=

# SABnzbd
# SABNZBD_URL=http://sabnzbd:8080
# SABNZBD_API_KEY=your_sabnzbd_api_key_here
# SABNZBD_CATEGORY=audiobooks

# Torrent client (qBittorrent / Transmission)
# TORRENT_URL=http://qbittorrent:8090
# TORRENT_USERNAME=admin
# TORRENT_PASSWORD=adminadmin
# TORRENT_CATEGORY=audiobooks
# TORRENT_SAVE_PATH=/downloads/audiobooks

# --- Optional: post-processing ------------------------------------------

# client  — download client handles moving files (default)
# bookscout — BookScout moves/renames files into POSTPROCESS_LIBRARY_ROOT
POSTPROCESS_MODE=client

# Required when POSTPROCESS_MODE=bookscout
# Must match the volume mount path in docker-compose.yml
# POSTPROCESS_LIBRARY_ROOT=/audiobooks

# --- Optional: application ----------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
