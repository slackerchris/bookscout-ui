        "jsCode": "const responses = $input.all();\nconst candidates = $('Prepare Candidate Imports').all();\n\nreturn responses.map((responseItem, i) => {\n  const response = responseItem.json;\n  const prev = candidates[i]?.json ?? {};\n  return {\n    json: {\n      ...prev,\n      importStatusCode: response.statusCode ?? 200,\n      importResponse: response.body ?? response,\n    },\n  };\n});"
      },
