    {
      "parameters": {
        "jsCode": "const headers = $json.headers || {};\nconst setCookie = headers['set-cookie'] || headers['Set-Cookie'] || [];\nlet cookie = '';\nif (Array.isArray(setCookie)) {\n  const sid = setCookie.find(c => c.startsWith('SID='));\n  if (sid) cookie = sid.split(';')[0];\n} else if (typeof setCookie === 'string' && setCookie.startsWith('SID=')) {\n  cookie = setCookie.split(';')[0];\n}\nif (!cookie) {\n  throw new Error('Could not extract SID cookie from qBittorrent login response');\n}\nreturn [{ json: { cookie } }];"
      },
      "id": "481f2075-1d58-40f6-a7e9-40d9702eef6f",
      "name": "Extract SID",
      "type": "n8n-nodes-base.code",
