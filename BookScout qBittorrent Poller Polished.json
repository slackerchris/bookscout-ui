      "id": "6912d108-bd61-43aa-afdd-b066f19c0648",
      "name": "Get Completed Audiobooks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1264,
        64
      ]
    },
    {
      "parameters": {
        "jsCode": "const allInputItems = $input.all();\nconst cookie = $('Extract SID').first().json.cookie;\nconst out = [];\n\nfor (let i = 0; i < allInputItems.length; i++) {\n  const t = allInputItems[i].json;\n  if (!t || typeof t !== 'object') continue;\n\n  const rawTags = String(t.tags || '')\n    .split(',')\n    .map(s => s.trim())\n    .filter(Boolean);\n\n  const tagMatch = rawTags\n    .map(tag => tag.match(/^bookscout-(\\d+)$/))\n    .find(Boolean);\n\n  if (!tagMatch || rawTags.includes('bs-imported') || rawTags.includes('bs-failed')) continue;\n\n  const bookId = tagMatch[1];\n  const savePath = String(t.save_path || '');\n  const normalizedSavePath = savePath && !savePath.endsWith('/') ? `${savePath}/` : savePath;\n  const contentPath = String(\n    t.content_path || (normalizedSavePath ? `${normalizedSavePath}${t.name}` : '')\n  ).trim();\n\n  if (!contentPath) continue;\n\n  out.push({\n    json: {\n      cookie,\n      hash: t.hash || '',\n      name: t.name || '',\n      category: t.category || '',\n      tags: t.tags || '',\n      tagsArray: rawTags,\n      bookId,\n      contentPath,\n      state: t.state || '',\n      progress: t.progress ?? null,\n      size: t.size ?? null,\n    },\n    pairedItem: { item: i },\n  });\n}\n\nreturn out;"
      },
